    "build": "pnpm --filter \"*\" run build",
    "dev": "pnpm --filter \"*playground*\" run dev",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "eslint": "10.1.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  }
}
