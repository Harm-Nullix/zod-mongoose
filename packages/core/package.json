{
  "version": "1.0.9",
  "name": "@nullix/zod-mongoose",
  "description": "Create Mongoose schemas using Zod v4.",
  "scripts": {
    "lint:eslint": "eslint",
    "lint:eslint:fix": "eslint --fix",
    "lint:editorconfig": "editorconfig-checker --exclude .git --exclude dist --exclude *.md",
    "lint:types": "tsc --noEmit",
    "lint": "pnpm lint:editorconfig && pnpm lint:types && pnpm lint:eslint",
    "test:unit": "bun test",
    "test:unit:watch": "bun test --watch",
    "test": "pnpm lint && pnpm test:unit",
    "build": "rimraf dist && rollup -c",
    "prepublishOnly": "pnpm test && pnpm build",
    "publish": "pnpm publish --access public"
  },
  "homepage": "https://zodmongoose.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Harm-Nullix/zod-mongoose"
  },
  "bugs": {
    "url": "https://github.com/Harm-Nullix/zod-mongoose/issues/new"
  },
  "keywords": [
    "mongoose",
    "zod",
    "mongodb"
  ],
  "author": "harm@nullix.nl",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": false,
    "endOfLine": "lf"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.3",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.10",
    "@types/lodash": "4.17.23",
    "@types/node": "24.12.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "bumpp": "11.0.1",
    "bun": "1.3.11",
    "editorconfig-checker": "6.1.1",
    "eslint": "10.1.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-typescript": "1.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-optimize-regex": "1.2.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-require-extensions": "0.1.3",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "lodash": "4.17.23",
    "mongodb-memory-server": "11.0.1",
    "mongoose": "8.23.0",
    "prettier": "3.8.1",
    "release-it": "19.2.4",
    "rimraf": "6.1.3",
    "rollup": "4.60.0",
    "rollup-plugin-dts": "6.4.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "mongoose": "^8.x",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "mongoose": {
      "optional": true
    }
  },
  "dependencies": {
    "hookable": "^6.1.0"
  }
}
